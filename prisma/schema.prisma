generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Lookup: rule sections (e.g. 1-5)
model sections {
  id          Int     @id
  code        String? @unique
  name        String
  description String?
  rules       rules[]
}

/// Lookup: rule types/subsections (e.g. 1-4)
model rule_types {
  id          Int     @id
  name        String  @unique
  description String?
  rules       rules[]
}

/// Lookup: decision-making bodies
model decision_bodies {
  id             Int              @id
  code           String           @unique
  name           String
  description    String?
  rule_decisions rule_decisions[]
  rules          rules[]
}

/// Lookup: categories a rule can apply to
model applies_to {
  id              Int               @id
  name            String            @unique
  description     String?
  rule_applies_to rule_applies_to[]
}

/// Lookup: rule statuses (1=active, 2=archived)
model rule_statuses {
  id          Int     @id
  name        String  @unique
  description String?
  rules       rules[]
}

/// Lookup: document groups (1=organizational rules, 2=personal decisions)
model doc_group {
  id    Int     @id(map: "doc_group_pk")
  group String?
}

/// Core table: rules and decisions
model rules {
  rule_uid         Int               @id @default(autoincrement())
  section_id       Int?
  rule_type_id     Int?
  id               Int?
  sub_id           Int?
  status_id        Int
  decision_body_id Int?
  decision_date    DateTime?         @db.Date
  decision_note    String?
  summary          String?
  text             String
  group_id         Int?
  persona          String?
  rule_applies_to  rule_applies_to[]
  rule_decisions   rule_decisions[]
  decision_body    decision_bodies?  @relation(fields: [decision_body_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rule_type        rule_types?       @relation(fields: [rule_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  section          sections?         @relation(fields: [section_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  status           rule_statuses     @relation(fields: [status_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([decision_date], map: "idx_rules_decision_dt")
  @@index([section_id, rule_type_id], map: "idx_rules_section_type")
  @@index([status_id], map: "idx_rules_status")
}

/// Junction: rule <-> category assignment
model rule_applies_to {
  rule_uid      Int
  applies_to_id Int
  applies_to    applies_to @relation(fields: [applies_to_id], references: [id], onUpdate: NoAction)
  rule          rules      @relation(fields: [rule_uid], references: [rule_uid], onDelete: Cascade, onUpdate: NoAction)

  @@id([rule_uid, applies_to_id])
  @@index([rule_uid], map: "idx_rule_applies_to_rule")
  @@index([applies_to_id], map: "idx_rule_applies_to_target")
}

/// AI vector embeddings per rule
model rule_embeddings {
  rule_uid  Int                   @id
  content   String
  metadata  Json
  embedding Unsupported("vector")

  @@index([embedding])
}

/// User roles: admin (id=1), viewer (id=2)
/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model user_group {
  id   Int?
  name String?

  @@ignore
}

/// Application users
model users {
  id            Int     @id @default(autoincrement())
  email         String?
  name          String?
  category      Int?
  user_group_id Int?
  password      String?
}

model document_metadata {
  id         String    @id @db.VarChar
  title      String    @db.VarChar
  url        String?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  schema     String?   @db.VarChar
}

model documents {
  id        String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content   String?
  metadata  Json?
  embedding Unsupported("vector")?
}

model error_log {
  id         Int       @id @default(autoincrement())
  error_type String    @db.VarChar
  file_id    String?   @db.VarChar
  file_name  String?   @db.VarChar
  file_size  String?   @db.VarChar
  mime_type  String?   @db.VarChar
  timestamp  DateTime? @default(now()) @db.Timestamp(6)
}

model n8n_chat_histories {
  id         Int    @id @default(autoincrement())
  session_id String @db.VarChar
  message    Json
}

model rule_decisions {
  id               Int             @id
  rule_uid         Int
  decision_body_id Int
  decision_date    DateTime        @db.Date
  note             String?
  is_current       Boolean?        @default(false)
  decision_bodies  decision_bodies @relation(fields: [decision_body_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rules            rules           @relation(fields: [rule_uid], references: [rule_uid], onDelete: Cascade, onUpdate: NoAction)

  @@index([rule_uid], map: "idx_rule_decisions_rule")
}
